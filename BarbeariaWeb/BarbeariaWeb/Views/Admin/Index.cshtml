@model List<Agendamento>

@functions {
    public string GetStatusBadge(string status)
    {
        return status switch
        {
            "Agendado" => "<span class='badge bg-warning text-dark px-3 py-2'>Agendado</span>",
            "Cancelado" => "<span class='badge bg-danger px-3 py-2'>Cancelado</span>",
            _ => "<span class='badge bg-success px-3 py-2'>Concluído</span>"
        };
    }
}

<div class="container-fluid px-3 px-md-5 py-4">

    <div class="d-flex justify-content-end align-items-center mb-3 gap-2">

        <a asp-controller="Admin"
           asp-action="AlterarSenha"
           class="btn btn-outline-secondary btn-sm">
            Trocar Senha
        </a>

        <a asp-controller="Admin"
           asp-action="Logout"
           class="btn btn-outline-danger btn-sm">
           Sair
        </a>

    </div>

    <!-- HEADER -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            

            <div>
                <h3 class="fw-bold mb-1">Dashboard de Agendamentos</h3>
                <small class="text-muted">
                    Visão geral do dia
                    <strong>@(((DateTime)ViewBag.DataSelecionada).ToString("dd/MM/yyyy"))</strong>
                </small>
            </div>

            <form method="get" class="d-flex gap-2 w-100 w-md-auto">
                <input type="date"
                       name="data"
                       value="@(((DateTime)ViewBag.DataSelecionada).ToString("yyyy-MM-dd"))"
                       class="form-control" />
                <button type="submit" class="btn btn-primary px-4">
                    Filtrar
                </button>
            </form>

        </div>
    </div>

    <!-- AÇÕES RÁPIDAS -->
    <div class="row g-3 mb-4">

        <div class="col-12 col-md-6">
            <a asp-controller="AdminCadastro"
               asp-action="Barbeiros"
               class="card border-0 shadow-sm h-100 text-decoration-none dashboard-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="icon-circle bg-dark">
                        🧔
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Gerenciar Barbeiros</h6>
                        <small class="text-muted">Controle completo dos profissionais</small>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-12 col-md-6">
            <a asp-controller="AdminCadastro"
               asp-action="Servicos"
               class="card border-0 shadow-sm h-100 text-decoration-none dashboard-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="icon-circle bg-secondary">
                        ✂️
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Gerenciar Serviços</h6>
                        <small class="text-muted">Editar preços e duração</small>
                    </div>
                </div>
            </a>
        </div>

    </div>

    <!-- MÉTRICAS -->
    <div class="row g-3 mb-4">

        <div class="col-6 col-md-3">
            <div class="metric-card">
                <span>Total</span>
                <h2>@ViewBag.Total</h2>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="metric-card warning">
                <span>Agendados</span>
                <h2>@ViewBag.Agendados</h2>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="metric-card success">
                <span>Concluídos</span>
                <h2>@ViewBag.Concluidos</h2>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="metric-card danger">
                <span>Cancelados</span>
                <h2>@ViewBag.Cancelados</h2>
            </div>
        </div>

    </div>

    <!-- LISTA DESKTOP -->
    <div class="card border-0 shadow-sm d-none d-md-block">
        <div class="card-body p-0">

            @if (!Model.Any())
            {
                <div class="text-center p-5">
                    <h5 class="fw-bold">Nenhum agendamento</h5>
                    <small class="text-muted">Não há registros para esta data.</small>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Cliente</th>
                                <th>Telefone</th>
                                <th>Horário</th>
                                <th>Status</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model.OrderBy(x => x.DataHora))
                            {
                                <tr>
                                    <td class="fw-semibold">@a.NomeCliente</td>
                                    <td>@a.Telefone</td>
                                    <td class="fw-bold">
                                        @a.DataHora.ToDateTime().ToLocalTime().ToString("HH:mm")
                                    </td>
                                    <td>
                                        @Html.Raw(GetStatusBadge(a.Status))
                                    </td>
                                    <td class="text-end">
                                        @if (a.Status == "Agendado")
                                        {
                                            <a asp-action="Concluir"
                                               asp-route-id="@a.Id"
                                               class="btn btn-sm btn-success me-2">
                                                Concluir
                                            </a>
                                            <a asp-action="Cancelar"
                                               asp-route-id="@a.Id"
                                               class="btn btn-sm btn-outline-danger">
                                                Cancelar
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>

    <!-- LISTA MOBILE -->
    <div class="d-md-none">

        @foreach (var a in Model.OrderBy(x => x.DataHora))
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">
                        <strong>@a.NomeCliente</strong>
                        <span class="fw-bold">
                            @a.DataHora.ToDateTime().ToLocalTime().ToString("HH:mm")
                        </span>
                    </div>

                    <div class="text-muted small mb-3">
                        📞 @a.Telefone
                    </div>

                    @Html.Raw(GetStatusBadge(a.Status))

                    @if (a.Status == "Agendado")
                    {
                        <div class="d-grid gap-2 mt-3">
                            <a asp-action="Concluir"
                               asp-route-id="@a.Id"
                               class="btn btn-success">
                                Concluir Atendimento
                            </a>
                            <a asp-action="Cancelar"
                               asp-route-id="@a.Id"
                               class="btn btn-outline-danger">
                                Cancelar Atendimento
                            </a>
                        </div>
                    }

                </div>
            </div>
        }

    </div>

</div>

<style>
    .dashboard-card:hover {
        transform: translateY(-3px);
        transition: .2s;
    }

    .icon-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
    }

    .metric-card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
    }

        .metric-card span {
            font-size: 13px;
            color: #6c757d;
        }

        .metric-card h2 {
            font-weight: 700;
            margin-top: 5px;
        }

        .metric-card.warning h2 {
            color: #ffc107;
        }

        .metric-card.success h2 {
            color: #198754;
        }

        .metric-card.danger h2 {
            color: #dc3545;
        }
</style>