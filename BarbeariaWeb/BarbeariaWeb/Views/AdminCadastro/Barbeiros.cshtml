@model List<Barbeiro>

<h2 class="mb-4">🧔 Cadastro de Barbeiros</h2>

<form method="post" asp-action="CriarBarbeiro" class="mb-4">
    <div class="row">
        <div class="col-md-6">
            <input type="text" name="nome" class="form-control" placeholder="Nome do barbeiro" required />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary">Cadastrar</button>
        </div>
    </div>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Status</th>
            <th>Ação</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Nome</td>
                <td>@(b.Ativo ? "Ativo" : "Inativo")</td>
                <td>
                    <a asp-action="ToggleBarbeiro"
                       asp-route-id="@b.Id"
                       asp-route-ativo="@(!b.Ativo)"
                       class="btn btn-sm btn-warning">
                        @(b.Ativo ? "Desativar" : "Ativar")
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>