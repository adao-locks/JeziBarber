@model List<Servico>

<h2 class="mb-4">✂️ Cadastro de Serviços</h2>

<form method="post" asp-action="CriarServico" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="descricao" class="form-control" placeholder="Descrição" required />
        </div>
        <div class="col-md-3">
            <input type="number" name="duracaoMinutos" class="form-control" placeholder="Duração (min)" required />
        </div>
        <div class="col-md-3">
            <input type="number" step="0.01" name="valor" class="form-control" placeholder="Valor" required />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary">Cadastrar</button>
        </div>
    </div>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Descrição</th>
            <th>Duração</th>
            <th>Valor</th>
            <th>Status</th>
            <th>Ação</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Descricao</td>
                <td>@s.DuracaoMinutos min</td>
                <td>R$ @s.Valor</td>
                <td>@(s.Ativo ? "Ativo" : "Inativo")</td>
                <td>
                    <a asp-action="ToggleServico"
                       asp-route-id="@s.Id"
                       asp-route-ativo="@(!s.Ativo)"
                       class="btn btn-sm btn-warning">
                        @(s.Ativo ? "Desativar" : "Ativar")
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>