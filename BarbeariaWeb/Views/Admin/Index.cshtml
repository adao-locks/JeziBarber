@model List<Agendamento>

@functions {
    public string GetStatusBadge(string status)
    {
        return status switch
        {
            "Agendado" => "<span class='badge bg-warning text-dark'>Agendado</span>",
            "Cancelado" => "<span class='badge bg-danger'>Cancelado</span>",
            _ => "<span class='badge bg-success'>Concluído</span>"
        };
    }
}

<div class="container-fluid px-3 px-md-5 py-4">

    <!-- TOPO -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">

        <div>
            <h3 class="fw-bold mb-1">📅 Dashboard de Agendamentos</h3>
            <small class="text-muted">
                Agenda do dia
                <strong>@(((DateTime)ViewBag.DataSelecionada).ToString("dd/MM/yyyy"))</strong>
            </small>
        </div>

        <div class="d-flex gap-2">

            <a asp-controller="Admin"
               asp-action="AlterarSenha"
               class="btn btn-outline-secondary btn-sm">
                ⚙ Trocar Senha
            </a>

            <a asp-controller="Admin"
               asp-action="Logout"
               class="btn btn-outline-danger btn-sm">
                Sair
            </a>

        </div>

    </div>

    <!-- FILTRO -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">

            <form method="get" class="row g-2 align-items-end">

            <div class="mb-3">

                <div class="btn-group">

                    <a href="?data=@(((DateTime)ViewBag.DataSelecionada).ToString("yyyy-MM-dd"))&modo=dia"
                            class="btn @(ViewBag.Modo == "dia" ? "btn-primary" : "btn-outline-primary")">
                        Dia
                    </a>

                    <a href="?data=@(((DateTime)ViewBag.DataSelecionada).ToString("yyyy-MM-dd"))&modo=mes"
                            class="btn @(ViewBag.Modo == "mes" ? "btn-primary" : "btn-outline-primary")">
                        Mês
                    </a>

                </div>

            </div>

            <input type="hidden" name="modo" value="@ViewBag.Modo" />

            <div class="col-6 col-md-2">
            <label class="form-label small">Data</label>
            <input type="date"
                   name="data"
                   value="@(((DateTime)ViewBag.DataSelecionada).ToString("yyyy-MM-dd"))"
                   class="form-control">
            </div>

            <div class="col-6 col-md-2">
            <label class="form-label small">Hora</label>
            <input type="time"
                   name="hora"
                   value="@ViewBag.HoraFiltro"
                   class="form-control">
            </div>

            <div class="col-12 col-md-2">
            <label class="form-label small">Status</label>
            <select name="status" class="form-select">

            <option value="">Todos</option>

            <option value="Agendado" selected="@(ViewBag.StatusFiltro == "Agendado" ? "selected" : null)">Agendado</option>

            <option value="Concluido" selected="@(ViewBag.StatusFiltro == "Concluido" ? "selected" : null)">Concluído</option>

            <option value="Cancelado" selected="@(ViewBag.StatusFiltro == "Cancelado" ? "selected" : null)">Cancelado</option>

            </select>
            </div>

            <div class="col-12 col-md-2">
            <label class="form-label small">Nome</label>
            <input type="text"
                   name="nome"
                   value="@ViewBag.NomeFiltro"
                   class="form-control"
                   placeholder="Cliente">
            </div>

            <div class="col-12 col-md-2">
            <label class="form-label small">Telefone</label>
            <input type="text"
                   name="telefone"
                   value="@ViewBag.TelefoneFiltro"
                   class="form-control"
                   placeholder="Telefone">
            </div>

            <div class="col-12 col-md-2 d-grid">
            <button class="btn btn-primary">
            Filtrar
            </button>
            </div>

                <a href="/Admin" class="btn btn-outline-secondary">
                    Limpar
                </a>

            </form>

        </div>
    </div>


    <!-- AÇÕES RÁPIDAS -->
    <div class="row g-3 mb-4">

        <div class="col-12 col-md-6">
            <a asp-controller="AdminCadastro"
               asp-action="Barbeiros"
               class="card border-0 shadow-sm h-100 text-decoration-none dashboard-card">

                <div class="card-body d-flex align-items-center gap-3">

                    <div class="icon-circle bg-dark">
                        🧔
                    </div>

                    <div>
                        <h6 class="fw-bold mb-1">Gerenciar Barbeiros</h6>
                        <small class="text-muted">
                            Controle de profissionais
                        </small>
                    </div>

                </div>

            </a>
        </div>

        <div class="col-12 col-md-6">
            <a asp-controller="AdminCadastro"
               asp-action="Servicos"
               class="card border-0 shadow-sm h-100 text-decoration-none dashboard-card">

                <div class="card-body d-flex align-items-center gap-3">

                    <div class="icon-circle bg-secondary">
                        ✂️
                    </div>

                    <div>
                        <h6 class="fw-bold mb-1">Gerenciar Serviços</h6>
                        <small class="text-muted">
                            Preços e duração
                        </small>
                    </div>

                </div>

            </a>
        </div>

    </div>


    <!-- MÉTRICAS -->
    <div class="row g-3 mb-4">

        <div class="col-6 col-md-3">
            <div class="metric-card">
                <span>Total</span>
                <h2>@ViewBag.Total</h2>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="metric-card warning">
                <span>Agendados</span>
                <h2>@ViewBag.Agendados</h2>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="metric-card success">
                <span>Concluídos</span>
                <h2>@ViewBag.Concluidos</h2>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="metric-card danger">
                <span>Cancelados</span>
                <h2>@ViewBag.Cancelados</h2>
            </div>
        </div>

    </div>


    <!-- LISTA DESKTOP -->
    <div class="card border-0 shadow-sm d-none d-md-block">

        <div class="card-body p-0">

            @if (!Model.Any())
            {
                <div class="text-center p-5">
                    <h5 class="fw-bold">Nenhum agendamento</h5>
                    <small class="text-muted">
                        Não há agendamentos nesta data.
                    </small>
                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Cliente</th>
                                <th>Telefone</th>
                                <th class="@(ViewBag.Modo == "dia" ? "d-none" : "")">Data</th>
                                <th>Horário</th>
                                <th>Status</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var a in Model.OrderBy(x => x.DataHora))
                            {
                                <tr id="agendamento-@a.Id">

                                    <td class="fw-semibold">
                                        @a.NomeCliente
                                    </td>

                                    <td>
                                        @a.Telefone
                                    </td>

                                    <td class="@(ViewBag.Modo == "dia" ? "d-none" : "")">
                                        @a.DataHora.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy")
                                    </td>

                                    <td class="fw-bold">
                                        @a.DataHora.ToDateTime().ToLocalTime().ToString("HH:mm")
                                    </td>

                                    <td>
                                        @Html.Raw(GetStatusBadge(a.Status))
                                    </td>

                                    <td class="text-end">

                                        @if (a.Status == "Agendado")
                                        {
                                            <button class="btn btn-sm btn-success me-2"
                                                    onclick="alterarStatus('@a.Id','Concluido')">
                                                Concluir
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger"
                                                    onclick="alterarStatus('@a.Id','Cancelado')">
                                                Cancelar
                                            </button>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>

    </div>


    <!-- MOBILE -->
    <div class="d-md-none">

        @foreach (var a in Model.OrderBy(x => x.DataHora))
        {
            <div class="card border-0 shadow-sm mb-3" data-id="@a.Id">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <strong>@a.NomeCliente</strong>

                        <span class="fw-bold">
                            @a.DataHora.ToDateTime().ToLocalTime().ToString("HH:mm")
                        </span>

                    </div>

                    <div class="text-muted small mb-2">
                        📞 @a.Telefone
                    </div>

                    <div class="mb-2 status-badge">
                        @Html.Raw(GetStatusBadge(a.Status))
                    </div>

                    @if (a.Status == "Agendado")
                    {
                        <div class="d-grid gap-2 mt-2">

                            <button class="btn btn-success"
                                    onclick="alterarStatus('@a.Id','Concluido')">
                                Concluir
                            </button>

                            <button class="btn btn-outline-danger"
                                    onclick="alterarStatus('@a.Id','Cancelado')">
                                Cancelar
                            </button>

                        </div>
                    }

                </div>

            </div>
        }

    </div>

</div>


<style>

    .dashboard-card:hover {
        transform: translateY(-4px);
        transition: .2s;
    }

    .icon-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
    }

    .metric-card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
    }

        .metric-card span {
            font-size: 13px;
            color: #6c757d;
        }

        .metric-card h2 {
            font-weight: 700;
            margin-top: 5px;
        }

        .metric-card.warning h2 {
            color: #ffc107;
        }

        .metric-card.success h2 {
            color: #198754;
        }

        .metric-card.danger h2 {
            color: #dc3545;
        }

</style>

<script>

    async function alterarStatus(id, status) {

        if (!confirm("Confirmar alteração de status?"))
            return;

        try {

            const response = await fetch("/Admin/AlterarStatus", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    id: id,
                    status: status
                })
            });

            const result = await response.json();

            if (!result.sucesso) {
                alert("Erro ao atualizar.");
                return;
            }

            // DESKTOP
            const linha = document.getElementById("agendamento-" + id);

            if (linha) {

                let badge = "";

                if (status === "Concluido")
                    badge = "<span class='badge bg-success'>Concluído</span>";

                if (status === "Cancelado")
                    badge = "<span class='badge bg-danger'>Cancelado</span>";

                linha.querySelector("td:nth-child(5)").innerHTML = badge;
                linha.querySelector("td:last-child").innerHTML = "";
            }

            // MOBILE
            const card = document.querySelector(`[data-id='${id}']`);

            if (card) {

                let badge = "";

                if (status === "Concluido")
                    badge = "<span class='badge bg-success'>Concluído</span>";

                if (status === "Cancelado")
                    badge = "<span class='badge bg-danger'>Cancelado</span>";

                const statusBadge = card.querySelector(".status-badge");

                if (statusBadge)
                    statusBadge.innerHTML = badge;

                const botoes = card.querySelector(".d-grid");

                if (botoes)
                    botoes.remove();
            }

        }
        catch (e) {
            alert("Erro ao comunicar com servidor.");
            console.error(e);
        }

    }

</script>